{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-utils/schema.json",
  "productName": "gnz",
  "version": "0.1.0",
  "identifier": "com.gnz.app",
  "build": {
    "beforeDevCommand": "pnpm --filter gnz-ui dev",
    "beforeBuildCommand": "pnpm --filter gnz-ui build",
    "frontendDist": "../ui/dist",
    "devUrl": "http://localhost:5173"
  },
  "app": {
    "windows": [
      {
        "title": "gnz",
        "width": 1200,
        "height": 800,
        "decorations": true,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png"
    ],
    "externalBin": [
      "binaries/gnz-backend"
    ]
  },
  "plugins": {
    "shell": {
      "open": true
    }
  }
}
